{
  "editText": {
    "label": "编辑文本",
    "controls": [
      {
        "id": "textNumber",
        "type": "text",
        "target": ".largeText",
        "label": "数字"
      },
      {
        "id": "textCN",
        "type": "text",
        "target": ".textCN",
        "label": "中文"
      },
      {
        "id": "textEN",
        "type": "text",
        "target": ".textEN",
        "label": "英文"
      },
      {
        "id": "textAlign",
        "type": "dropdown",
        "label": "对齐",
        "options": [
          { "name": "左", "value": "left" },
          { "name": "中", "value": "center" },
          { "name": "右", "value": "right" }
        ],
        "useList": true
      }
    ]
  },
  "rotateIcon": {
    "label": "旋转角度",
    "controls": [
      {
        "id": "iconDirection",
        "type": "select",
        "target": ".icon",
        "label": "方向",
        "options": [
          {
            "name": "上 ↑",
            "value": "rotate(0deg)"
          },
          {
            "name": "下 ↓",
            "value": "rotate(180deg)"
          },
          {
            "name": "左 ←",
            "value": "rotate(270deg)"
          },
          {
            "name": "右 →",
            "value": "rotate(90deg)"
          },
          {
            "name": "左上 ↖",
            "value": "rotate(315deg)"
          },
          {
            "name": "右上 ↗",
            "value": "rotate(45deg)"
          },
          {
            "name": "左下 ↙",
            "value": "rotate(225deg)"
          },
          {
            "name": "右下 ↘",
            "value": "rotate(135deg)"
          }
        ]
      }
    ]
  },
  "selectLine": {
    "label": "线路设置",
    "controls": [
      {
        "id": "lineDropdown",
        "type": "dropdown",
        "label": ""
      },
      {
        "id": "lineCustomColor",
        "type": "color",
        "target": ".colorBar",
        "label": "自定义线路色"
      }
    ]
  },
  "selectIcon": {
    "label": "选择图标",
    "controls": [
      {
        "id": "iconDropdown",
        "type": "dropdown",
        "target": "img"
      }
    ]
  },
  "selectFacility": {
    "label": "选择设施",
    "controls": [
      {
        "id": "facilityDropdown",
        "type": "dropdown",
        "target": "img"
      }
    ]
  },
  "zoneSettings": {
    "label": "区域设置",
    "controls": [
      {
        "id": "zoneWidth",
        "type": "dropdown",
        "label": "字宽",
        "options": [
          { "name": "标准", "value": "normal" },
          { "name": "紧缩", "value": "condensed" }
        ],
        "useList": true
      },
      {
        "id": "zoneAlign",
        "type": "dropdown",
        "label": "对齐",
        "options": [
          { "name": "左", "value": "left" },
          { "name": "中", "value": "center" },
          { "name": "右", "value": "right" }
        ],
        "useList": true
      }
    ]
  },
  "advancedOptions": {
    "label": "高级选项",
    "controls": [
      {
        "id": "widthMode",
        "type": "widthMode",
        "label": "宽度模式"
      },
      {
        "id": "letterSpacing",
        "type": "number",
        "target": "self",
        "label": "文字间距(px)",
        "step": 0.5,
        "property": "letterSpacing"
      }
    ]
  },
  "editColor": {
    "label": "颜色设置",
    "controls": [
      {
        "id": "colorBarColor",
        "type": "color",
        "target": ".colorBar",
        "label": "色带颜色"
      }
    ]
  }
}